# 复制此文件为 .env 并填入真实凭证，.env 已在 .gitignore 中，不会提交
#
# Kimi-K2.5 (Azure) / Azure OpenAI 凭证
# 格式: API Base URL|||API Key
# 示例: https://your-resource.openai.azure.com/openai/v1|||sk-xxxxxxxx
AZURE_OPENAI_CREDENTIALS=https://xxx.azure.com/openai/v1|||你的API_KEY

# Custom (OpenAI) 自定义 OpenAI 兼容 API
# 格式: API Base URL|||API Key|||模型名 (模型名可选，默认 gpt-4o)
# 示例: https://api.xxx.com/v1|||sk-xxx|||gpt-4o
CUSTOM_OPENAI_CREDENTIALS=https://api.xxx.com/v1|||sk-xxx|||gpt-4o

# 其他可选 API Keys（如需在界面中预填）
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# QWEN_API_KEY=sk-xxx

# Ollama 本地模型 API Base（默认 http://localhost:11434）
# OLLAMA_API_BASE=http://localhost:11434

# 飞书网关 (参考 OpenClaw)，不要加引号
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_DOMAIN=https://open.feishu.cn
# FEISHU_PLANNER_MODEL=gpt-4o  或 Kimi-K2.5 (Azure)
# FEISHU_PLANNER_PROVIDER=openai  或 azure（用 Kimi 时需配合 AZURE_OPENAI_CREDENTIALS）
